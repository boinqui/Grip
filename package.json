{
  "name": "grip",
  "version": "1.0.0",
  "description": "A ordem do dia está na sua tela",
  "main": "script.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./input.css -o ./style.css",
    "dev:css": "npx @tailwindcss/cli -i ./input.css -o ./style.css --watch",
    "dev:server": "npx serve . -l 5500",
    "dev": "concurrently -k \"npm:dev:css\" \"npm:dev:server\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
