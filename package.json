  },
  "homepage": "https://github.com/boinqui/Grip#readme",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "serve": "^14.2.4",
    "tailwindcss": "^4.2.1"
  }
